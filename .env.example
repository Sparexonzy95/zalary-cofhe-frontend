# =============================================================================
# Zalary Zama Frontend Environment Example
# =============================================================================
# Copy this file to .env before running the frontend:
#
#   cp .env.example .env
#
# Windows PowerShell:
#
#   Copy-Item .env.example .env
#
# IMPORTANT:
# - Vite exposes every VITE_* variable to the browser.
# - Do NOT put private keys, wallet secrets, backend database passwords,
#   production credentials, or sensitive server-only secrets here.
# - Keep private/runtime secrets inside the backend or worker environment only.
# =============================================================================


# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
# Local Django backend URL.
# For production, replace with your deployed backend API domain.
VITE_API_BASE_URL=http://127.0.0.1:8000

# API key expected by protected backend action endpoints.
# This is visible in the browser because it starts with VITE_.
# Use only if your backend treats this as a public/client key.
# Never place a high-privilege backend secret here.
VITE_API_KEY=change-me-to-your-backend-api-key


# -----------------------------------------------------------------------------
# Chain Configuration
# -----------------------------------------------------------------------------
# Ethereum Sepolia testnet.
VITE_CHAIN_ID=11155111
VITE_CHAIN_NAME=Ethereum Sepolia

# RPC URL used by frontend/worker-aware flows.
# You can replace this with Alchemy, Infura, QuickNode, Ankr, or your own RPC.
VITE_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Backend Chain model/database ID.
# Must match the active Chain row seeded in the Django backend.
VITE_CHAIN_DB_ID=1


# -----------------------------------------------------------------------------
# Zalary Zama Contract Addresses
# -----------------------------------------------------------------------------
# These addresses must match the backend chain configuration and deployed contracts.

# ConfidentialToken contract
VITE_CONFIDENTIAL_TOKEN_ADDRESS=0xeb517F61CA9cbffa93ddB4a1452257AeF41058B3

# PayrollVault contract
VITE_PAYROLL_VAULT_ADDRESS=0x2C4C63213Ac5b0fd23B6f468709137C9d80C82B7

# SwapRouter contract
VITE_SWAP_ROUTER_ADDRESS=0x95FB006A9f3493b69054BcdcA5Cf96C5C43e91Da


# -----------------------------------------------------------------------------
# Worker / Relayer Bridge
# -----------------------------------------------------------------------------
# Frontend-facing worker path.
#
# Local option:
#   VITE_VIEM_WORKER_URL=http://127.0.0.1:8787
#
# Production proxy option:
#   VITE_VIEM_WORKER_URL=/zama-worker
#
# Use /zama-worker when your frontend host or Nginx/Vercel rewrites proxy
# requests to the real worker service.
VITE_VIEM_WORKER_URL=/zama-worker


# -----------------------------------------------------------------------------
# Optional App Metadata
# -----------------------------------------------------------------------------
# These are optional but useful for UI labels, debugging, and deployment checks.
VITE_APP_NAME=Zalary
VITE_APP_ENV=development
VITE_APP_VERSION=1.0.0
