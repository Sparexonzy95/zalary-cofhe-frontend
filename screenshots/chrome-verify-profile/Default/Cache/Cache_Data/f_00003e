y: var(--z-display);\n  font-size: 1rem;\n  font-weight: 700;\n  margin: 0;\n  color: var(--z-text);\n}\n.empty-state p {\n  font-size: 0.84rem;\n  color: var(--z-muted);\n  max-width: 360px;\n  line-height: 1.65;\n  margin: 0;\n}\n\n/* ═══════════════════════════════════════════════════════════\n   ADDRESS / TX PILLS\n═══════════════════════════════════════════════════════════ */\n.address-pill {\n  display: inline-flex;\n  align-items: center;\n  gap: 0.35rem;\n  font-family: var(--z-mono);\n  font-size: 0.7rem;\n  color: var(--z-muted);\n  background: var(--z-panel);\n  border: 1px solid var(--z-border);\n  padding: 0.28rem 0.65rem;\n  border-radius: 6px;\n  white-space: nowrap;\n  cursor: default;\n  transition: border-color .15s;\n}\n.address-pill:hover { border-color: var(--z-border-strong); }\n\na.address-pill {\n  color: rgba(254,158,21,.85);\n  border-color: rgba(254,158,21,.2);\n  background: rgba(254,158,21,.06);\n  cursor: pointer;\n  text-decoration: none;\n}\na.address-pill:hover {\n  border-color: rgba(254,158,21,.45);\n  color: var(--z-accent);\n}\n\n/* ═══════════════════════════════════════════════════════════\n   PAGE HEADER (inside shell pages)\n═══════════════════════════════════════════════════════════ */\n.page-header {\n  padding: 0 0 1.55rem;\n  border-bottom: 1px solid var(--z-border);\n  margin-bottom: 0.25rem;\n  display: flex;\n  justify-content: space-between;\n  align-items: flex-start;\n  gap: 1.5rem;\n  flex-wrap: wrap;\n}\n.page-header-eyebrow {\n  font-family: var(--z-mono);\n  font-size: 0.56rem;\n  letter-spacing: 0.14em;\n  text-transform: uppercase;\n  color: var(--z-accent);\n  margin-bottom: 0.75rem;\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n}\n.page-header-eyebrow::before {\n  content: '';\n  width: 16px;\n  height: 1px;\n  background: var(--z-accent);\n}\n.page-header h1 {\n  font-family: var(--z-display);\n  font-size: clamp(1.35rem, 3vw, 2rem);\n  font-weight: 760;\n  letter-spacing: -0.02em;\n  margin: 0