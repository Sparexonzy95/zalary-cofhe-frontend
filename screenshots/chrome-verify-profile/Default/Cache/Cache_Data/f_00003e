 font-weight: 800;\n  line-height: 0.95;\n  letter-spacing: -0.05em;\n  margin: 0 0 1rem;\n}\n.onboarding-hero p {\n  color: var(--z-muted);\n  font-size: 0.95rem;\n  line-height: 1.7;\n}\n.eyebrow {\n  font-family: var(--z-mono);\n  font-size: 0.6rem;\n  letter-spacing: 0.14em;\n  text-transform: uppercase;\n  color: var(--z-accent);\n  margin-bottom: 0.875rem;\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n}\n.eyebrow::before {\n  content: '';\n  width: 14px;\n  height: 1px;\n  background: var(--z-accent);\n}\n.onboarding-grid {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: 1.25rem;\n}\n.form-stack { display: grid; gap: 1rem; }\n.success-box {\n  border: 1px solid rgba(254,158,21,.25);\n  background: rgba(254,158,21,.07);\n  border-radius: var(--z-radius-sm);\n  padding: 0.875rem 1rem;\n  font-size: 0.875rem;\n  color: var(--z-text);\n  line-height: 1.5;\n}\n.success-box strong { color: var(--z-accent); }\n.dev-code {\n  border: 1px solid rgba(254,158,21,.25);\n  background: rgba(254,158,21,.06);\n  border-radius: var(--z-radius-sm);\n  padding: 0.875rem 1rem;\n  font-family: var(--z-mono);\n  font-size: 0.8rem;\n  color: var(--z-accent);\n}\n.onboarding-identity-box { margin-top: 1.25rem; }\n.onboarding-wallet-row {\n  margin-top: 1.25rem;\n  display: flex;\n  align-items: center;\n  gap: 0.875rem;\n}\n\n/* ═══════════════════════════════════════════════════════════\n   WALLET CONNECT BUTTON\n═══════════════════════════════════════════════════════════ */\n.wallet-connect-wrap { display: inline-flex; flex-direction: column; gap: 4px; }\n.wallet-error { font-family: var(--z-mono); font-size: 0.68rem; color: var(--z-danger); }\n\n/* ═══════════════════════════════════════════════════════════\n   ACCOUNT PAGE\n═══════════════════════════════════════════════════════════ */\n.account-page { width: 100%; }\n.account-hero { margin-bottom: 2rem; }\n.account-hero h1 {\n  font-family: var(--z-display);\n  font-size: clamp(1.35rem, 3vw, 2rem);\n  font-weight: 760;\n  letter-spacing: -0.02em;\n  margin: 0.5rem 0 0.75rem;\n  line-height: 1.12;\n}\n.account-hero p { max-width: 600px; color: var(--z-muted); line-height: 1.7; font-size: 0.9rem; }\n.account-wallet-row { margin-top: 1.25rem; display: flex; align-items: center; gap: 0.75rem; }\n.account-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1.25rem; }\n.account-detail-list { display: grid; gap: 0; }\n.account-detail-row {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 1rem;\n  padding: 0.875rem 0;\n  border-bottom: 1px solid var(--z-border);\n}\n.account-detail-row:last-child { border-bottom: none; }\n.account-detail-row span { font-size: 0.85rem; color: var(--z-muted); }\n.account-detail-row strong { text-align: right; font-weight: 600; font-size: 0.85rem; color: var(--z-text); }\n.account-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; }\n.account-actions-spaced { margin-top: 1.25rem; }\n.account-help-text { margin-top: 1rem; line-height: 1.65; font-size: 0.88rem; color: var(--z-muted); }\n.account-tabs-shell {\n  display: grid;\n  gap: 1rem;\n}\n.account-tabs-menu {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(min(8.4rem, 100%), 1fr));\n  overflow: hidden;\n  border: 1px solid var(--dash-border, var(--z-border));\n  border-radius: 4px;\n  background: #111316;\n}\n.account-tab-button {\n  display: grid;\n  gap: 0.25rem;\n  min-height: 5rem;\n  padding: 0.9rem 1rem;\n  border: 0;\n  border-right: 1px solid var(--dash-border, var(--z-border));\n  background: transparent;\n  color: inherit;\n  text-align: left;\n  cursor: pointer;\n  transition: background 0.16s var(--z-ease), color 0.16s var(--z-ease);\n}\n.account-tab-button:last-child {\n  border-right: 0;\n}\n.account-tab-button:hover,\n.account-tab-button.active {\n  background: rgba(255,255,255,0.035);\n}\n.account-tab-button span,\n.account-tab-button small {\n  font-family: var(--z-mono